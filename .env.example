# Copy to .env and adjust as needed. All vars are prefixed RETAILREC_.
# (.env is gitignored — never commit real secrets.)

# ---- Sampling ----
RETAILREC_SAMPLE_USERS=50000
RETAILREC_SAMPLE_MIN_TRANSACTIONS=5

# ---- MLflow ----
RETAILREC_MLFLOW_TRACKING_URI=http://localhost:5000
RETAILREC_MLFLOW_EXPERIMENT=retailrec

# ---- MinIO / S3 ----
RETAILREC_S3_ENDPOINT_URL=http://localhost:9000
RETAILREC_S3_ACCESS_KEY=minioadmin
RETAILREC_S3_SECRET_KEY=minioadmin
RETAILREC_S3_BUCKET=retailrec
RETAILREC_AWS_REGION=us-east-1

# ---- Redis ----
RETAILREC_REDIS_HOST=localhost
RETAILREC_REDIS_PORT=6379

# ---- Postgres ----
RETAILREC_POSTGRES_HOST=localhost
RETAILREC_POSTGRES_PORT=5432
RETAILREC_POSTGRES_USER=retailrec
RETAILREC_POSTGRES_PASSWORD=retailrec
RETAILREC_POSTGRES_DB=retailrec

# ---- Kaggle (for data download; or place kaggle.json in ~/.kaggle/) ----
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_key
